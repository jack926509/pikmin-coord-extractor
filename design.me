<!DOCTYPE html>
<html class="light" lang="zh-TW">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Pikmin 座標提取器 - Botanical Archivist · Design Reference</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Be_Vietnam_Pro:wght@400;500;600&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script id="tailwind-config">
  tailwind.config = {
    darkMode: "class",
    theme: {
      extend: {
        colors: {
          "secondary-fixed":              "#ffd9e2",
          "surface-bright":               "#faf9f6",
          "tertiary-container":           "#81d4fa",
          "tertiary-fixed-dim":           "#72c6eb",
          "on-tertiary-fixed-variant":    "#00526b",
          "on-primary-fixed-variant":     "#366700",
          "primary-fixed":                "#b7f481",
          "on-primary-container":         "#2f5c00",
          "surface-container-lowest":     "#ffffff",
          "outline-variant":              "#b1b2af",
          "primary-fixed-dim":            "#a9e575",
          "inverse-primary":              "#bffd89",
          "inverse-on-surface":           "#9d9d9a",
          "outline":                      "#797b78",
          "on-secondary":                 "#fff7f7",
          "error":                        "#aa371c",
          "on-error-container":           "#671200",
          "on-error":                     "#fff7f6",
          "surface":                      "#faf9f6",
          "surface-container-low":        "#f4f4f0",
          "surface-container":            "#eeeeea",
          "primary-dim":                  "#305e00",
          "background":                   "#faf9f6",
          "tertiary-dim":                 "#005a75",
          "surface-dim":                  "#d9dbd6",
          "on-background":                "#303330",
          "secondary-fixed-dim":          "#ffc5d5",
          "error-dim":                    "#821a01",
          "surface-variant":              "#e1e3df",
          "on-secondary-container":       "#863655",
          "on-tertiary-container":        "#00485e",
          "primary":                      "#386b02",
          "on-surface-variant":           "#5d605c",
          "surface-container-highest":    "#e1e3df",
          "on-primary-fixed":             "#244800",
          "on-primary":                   "#edffd8",
          "secondary-container":          "#ffd9e2",
          "error-container":              "#fa7150",
          "surface-container-high":       "#e8e8e4",
          "on-tertiary":                  "#f3faff",
          "primary-container":            "#b7f481",
          "surface-tint":                 "#386b02",
          "inverse-surface":              "#0d0f0d",
          "tertiary":                     "#006786",
          "on-tertiary-fixed":            "#003343",
          "secondary-dim":                "#883756",
          "on-secondary-fixed":           "#6f2342",
          "secondary":                    "#974362",
          "tertiary-fixed":               "#81d4fa",
          "on-secondary-fixed-variant":   "#923f5f",
          "on-surface":                   "#303330"
        },
        borderRadius: {
          "DEFAULT": "1rem",
          "lg":      "2rem",
          "xl":      "3rem",
          "full":    "9999px"
        },
        fontFamily: {
          "headline": ["Plus Jakarta Sans"],
          "body":     ["Be Vietnam Pro"],
          "label":    ["Plus Jakarta Sans"]
        }
      }
    }
  }
</script>
<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
  body {
    background-color: #faf9f6;
    color: #303330;
    font-family: 'Be Vietnam Pro', sans-serif;
    min-height: max(884px, 100dvh);
  }
  textarea::placeholder { color: #5d605c; opacity: 0.6; }
</style>
</head>
<body class="min-h-screen pb-32">

<!-- ═══════════════════════════════════════════════════
     TOP APP BAR
     Glass-morphic sticky header, primary green brand
═══════════════════════════════════════════════════ -->
<header class="sticky top-0 z-50
               bg-[#faf9f6]/80 backdrop-blur-md
               shadow-[0_8px_32px_rgba(48,51,48,0.06)]
               flex items-center justify-between px-6 py-4 w-full">
  <div class="flex items-center gap-3">
    <span class="material-symbols-outlined text-xl text-[#386b02]">potted_plant</span>
    <h1 class="text-xl font-headline font-bold text-[#386b02]">Botanical Archivist</h1>
  </div>
  <button class="hover:opacity-80 active:scale-95 transition-all duration-200">
    <span class="material-symbols-outlined text-[#386b02]">settings</span>
  </button>
</header>

<main class="px-6 pt-8 max-w-2xl mx-auto space-y-10">

  <!-- ═══════════════════════════════════════════════
       HERO SECTION
       Large headline + subtitle
  ═══════════════════════════════════════════════ -->
  <section class="space-y-4">
    <div class="space-y-1">
      <h2 class="text-4xl font-headline font-extrabold tracking-tight text-on-background leading-tight">
        Pikmin <span class="text-primary">座標提取器</span>
      </h2>
      <p class="text-on-surface-variant font-body text-sm">整理繁雜的訊息，一鍵擷取座標存檔。</p>
    </div>

    <!-- ── INPUT CARD ──────────────────────────────
         Surface-container-low background, rounded-lg (2rem)
         Textarea: surface-container-high, rounded (1rem), no border
         Primary button: rounded-full, green, with shadow
         Clear: rounded-full ghost, error-dim text
    ──────────────────────────────────────────── -->
    <div class="bg-surface-container-low rounded-lg p-6 shadow-sm">
      <div class="relative group">
        <textarea class="w-full h-48
                         bg-surface-container-high border-none rounded-lg p-4
                         text-on-surface focus:ring-2 focus:ring-primary/20
                         focus:bg-surface-container-lowest outline-none resize-none
                         transition-all"
                  placeholder="在此貼上 Telegram 訊息内容..."></textarea>

        <div class="flex gap-3 mt-4">
          <button class="flex-1 text-on-primary font-headline font-bold py-4
                         rounded-full shadow-lg active:scale-95 transition-all duration-300
                         bg-[#7CB342]">
            擷取座標
          </button>
        </div>

        <div class="flex justify-center mt-3">
          <button class="w-1/2 bg-surface-container-lowest border border-outline-variant/30
                         text-error-dim font-label font-semibold py-3 rounded-full
                         hover:bg-error-container/10 transition-colors">
            清空
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       RESULTS SECTION
       Section header: headline bold + count label
       Result cards:
         · First card: border-l-4 border-primary (highlighted)
         · Others: surface-container-lowest, no left border
         · Icon circle: bg-tertiary-container/30, tertiary icon
         · Coord badge: bg-tertiary-container, on-tertiary-container text, rounded-full
         · Location label: text-sm text-on-surface-variant
         · Copy button: rounded-full, surface-container bg
  ═══════════════════════════════════════════════ -->
  <section class="space-y-6">
    <div class="flex items-center justify-between">
      <h3 class="text-xl font-headline font-bold text-on-background">擷取結果</h3>
      <span class="text-xs font-label uppercase tracking-widest text-on-surface-variant/60">
        找到 3 個座標
      </span>
    </div>

    <div class="space-y-4">
      <!-- Result Item 1 — ACTIVE (primary left border) -->
      <div class="bg-surface-container-lowest rounded-lg p-5
                  flex items-center justify-between shadow-sm
                  border-l-4 border-primary">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-tertiary-container/30
                      flex items-center justify-center">
            <span class="material-symbols-outlined text-tertiary">location_on</span>
          </div>
          <div class="space-y-1">
            <div class="bg-tertiary-container text-on-tertiary-container
                        px-3 py-1 rounded-full text-xs font-bold w-fit">
              25.0330, 121.5654
            </div>
            <p class="text-sm font-body text-on-surface-variant">台北市信義區</p>
          </div>
        </div>
        <button class="bg-surface-container text-primary p-3 rounded-full
                       hover:bg-primary-container transition-all active:scale-90">
          <span class="material-symbols-outlined">content_copy</span>
        </button>
      </div>

      <!-- Result Item 2 — default -->
      <div class="bg-surface-container-low rounded-lg p-5
                  flex items-center justify-between shadow-sm">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-tertiary-container/30
                      flex items-center justify-center">
            <span class="material-symbols-outlined text-tertiary">location_on</span>
          </div>
          <div class="space-y-1">
            <div class="bg-tertiary-container text-on-tertiary-container
                        px-3 py-1 rounded-full text-xs font-bold w-fit">
              24.1477, 120.6736
            </div>
            <p class="text-sm font-body text-on-surface-variant">台中市中區</p>
          </div>
        </div>
        <button class="bg-surface-container-lowest text-primary p-3 rounded-full
                       hover:bg-primary-container transition-all active:scale-90">
          <span class="material-symbols-outlined">content_copy</span>
        </button>
      </div>

      <!-- Result Item 3 — default -->
      <div class="bg-surface-container-lowest rounded-lg p-5
                  flex items-center justify-between shadow-sm">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-tertiary-container/30
                      flex items-center justify-center">
            <span class="material-symbols-outlined text-tertiary">location_on</span>
          </div>
          <div class="space-y-1">
            <div class="bg-tertiary-container text-on-tertiary-container
                        px-3 py-1 rounded-full text-xs font-bold w-fit">
              22.6273, 120.3014
            </div>
            <p class="text-sm font-body text-on-surface-variant">高雄市前鎮區</p>
          </div>
        </div>
        <button class="bg-surface-container text-primary p-3 rounded-full
                       hover:bg-primary-container transition-all active:scale-90">
          <span class="material-symbols-outlined">content_copy</span>
        </button>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       INFO / DECORATIVE CARD
       Background: secondary-container (#ffd9e2)
       Large decorative icon, 10% opacity, absolute positioned
  ═══════════════════════════════════════════════ -->
  <section class="bg-secondary-container rounded-lg p-6 relative overflow-hidden">
    <div class="relative z-10 space-y-2">
      <h4 class="font-headline font-bold text-on-secondary-container">檔案歸檔提示</h4>
      <p class="text-sm text-on-secondary-container/80 leading-relaxed font-body">
        所有擷取的座標將自動與「歷史紀錄」同步。您可以點擊下方的封存按鈕來整理您的 botanical collections。
      </p>
    </div>
    <div class="absolute -right-8 -bottom-8 opacity-10">
      <span class="material-symbols-outlined text-[120px]">eco</span>
    </div>
  </section>

</main>

<!-- ═══════════════════════════════════════════════════
     BOTTOM NAV BAR
     Glass-morphic, rounded-t-xl (3rem)
     Active tab: bg-primary pill with white text
     Inactive: text-on-surface/50, hover:text-primary
═══════════════════════════════════════════════════ -->
<nav class="fixed bottom-0 left-0 w-full
            flex justify-around items-center px-8 pb-6 pt-2
            bg-[#faf9f6]/80 backdrop-blur-md
            rounded-t-[3rem] z-50
            shadow-[0_-8px_32px_rgba(48,51,48,0.06)]">

  <!-- Active: Extractor -->
  <a class="flex flex-col items-center text-white bg-primary
            rounded-full p-3 mb-1 shadow-lg
            active:scale-90 transition-all duration-300" href="#">
    <span class="material-symbols-outlined">content_paste_search</span>
    <span class="font-body text-[11px] font-semibold uppercase tracking-widest mt-1">Extractor</span>
  </a>

  <!-- Inactive: History -->
  <a class="flex flex-col items-center text-[#303330]/50
            p-2 hover:text-[#386b02] transition-all active:scale-90 duration-300" href="#">
    <span class="material-symbols-outlined">history</span>
    <span class="font-body text-[11px] font-semibold uppercase tracking-widest mt-1">History</span>
  </a>

  <!-- Inactive: Archives -->
  <a class="flex flex-col items-center text-[#303330]/50
            p-2 hover:text-[#386b02] transition-all active:scale-90 duration-300" href="#">
    <span class="material-symbols-outlined">folder_zip</span>
    <span class="font-body text-[11px] font-semibold uppercase tracking-widest mt-1">Archives</span>
  </a>

</nav>
</body>
</html>
